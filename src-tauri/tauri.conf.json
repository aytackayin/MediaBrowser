{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Media Browser",
  "version": "1.0.0",
  "identifier": "com.aytackayin.mediabrowser",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Media Browser",
        "width": 1000,
        "height": 750,
        "resizable": true,
        "fullscreen": false,
        "maximized": true,
        "visible": true,
        "devtools": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' tauri: http://localhost:* ws://localhost:*; img-src * data: blob: tauri: asset:; media-src * data: blob: tauri: asset:; connect-src * data: blob: tauri: asset:; style-src * 'unsafe-inline'; font-src * data: tauri: asset:;",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**",
          "C:\\**",
          "D:\\**",
          "E:\\**",
          "F:\\**",
          "G:\\**",
          "H:\\**",
          "I:\\**",
          "\\\\?\\**",
          "*:\\**"
        ]
      }
    }
  },
  "plugins": {
    "fs": {}
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "bin/ffmpeg",
      "bin/ffprobe"
    ]
  }
}